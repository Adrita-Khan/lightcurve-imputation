   "source": [
    "# 02 – Missing-Data Injection\n",
    "\n",
    "Demonstrates MCAR gap injection with the 50/50 block/scattered mixture\n",
    "from Algorithm 2 (Gap Injection) of the thesis.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys; sys.path.insert(0, '..')\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from src.simulation.generator import generate_synthetic_lightcurve\n",
    "from src.missingness.injector import inject_gaps\n",
    "\n",
    "t, flux, params = generate_synthetic_lightcurve(N=1323, seed=0)\n",
    "fractions = [0.10, 0.30, 0.50]\n",
    "colors = ['#4daf4a', '#377eb8', '#e41a1c']"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(len(fractions), 1, figsize=(12, 7), sharex=True)\n",
    "\n",
    "for ax, frac, color in zip(axes, fractions, colors):\n",
    "    gapped, missing_idx, _ = inject_gaps(flux, p=frac, seed=42)\n",
    "    obs_mask = ~np.isnan(gapped)\n",
    "    miss_mask = ~obs_mask\n",
    "\n",
    "    ax.plot(t[obs_mask], gapped[obs_mask], '.', ms=1.5, color='#333333', label='Observed')\n",
    "    ax.fill_between(t, gapped.min() - 0.05, gapped.max() + 0.05,\n",
    "                    where=miss_mask, alpha=0.3, color=color, label=f'Gap ({frac*100:.0f}%)')\n",
    "    ax.set_ylabel('Flux')\n",
    "    ax.legend(loc='upper right')\n",
    "    actual_frac = miss_mask.sum() / len(gapped)\n",
    "    ax.set_title(f'Target: {frac*100:.0f}%   Actual: {actual_frac*100:.1f}%')\n",
    "    ax.grid(alpha=0.2)\n",
    "\n",
    "axes[-1].set_xlabel('Time (days)')\n",
    "plt.suptitle('MCAR gap injection at three missingness fractions', fontsize=12)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Reproducibility across different seeds\n",
    "_, idx1, _ = inject_gaps(flux, p=0.30, seed=1)\n",
    "_, idx2, _ = inject_gaps(flux, p=0.30, seed=1)\n",
    "_, idx3, _ = inject_gaps(flux, p=0.30, seed=2)\n",
    "\n",
    "print('Same seed → identical:', np.array_equal(idx1, idx2))\n",
    "print('Different seed → different:', not np.array_equal(idx1, idx3))\n",
    "print(f'Fraction p=0.30, seed=1: {len(idx1)/len(flux)*100:.1f}% missing')"
   ]
  }
 ],
